
@baseUrl = https://simracing-api.onrender.com
@token = TOKEN_HERE
@userId = USER_ID_HERE
@teamId = TEAM_ID_HERE
@raceId = RACE_ID_HERE
@registrationId = REGISTRATION_ID_HERE

### ROOT
GET {{baseUrl}}/

###

### REGISTER
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Batiste",
  "email": "batiste@email.com",
  "password": "test123"
}

###

### LOGIN
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "batiste@email.com",
  "password": "test123"
}

###

### ME
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{token}}

###

### USERS - GET ALL
GET {{baseUrl}}/api/users
Authorization: Bearer {{token}}

###

### USERS - GET BY ID
GET {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{token}}

###

### USERS - CREATE
POST {{baseUrl}}/api/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Admin User",
  "email": "admin@test.com",
  "password": "123456",
  "role": "admin"
}

###

### USERS - UPDATE
PUT {{baseUrl}}/api/users/{{userId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated User"
}

###

### USERS - DELETE
DELETE {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{token}}

###

### TEAMS - GET ALL
GET {{baseUrl}}/api/teams
Authorization: Bearer {{token}}

###

### TEAMS - GET BY ID
GET {{baseUrl}}/api/teams/{{teamId}}
Authorization: Bearer {{token}}

###

### TEAMS - CREATE
POST {{baseUrl}}/api/teams
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Red Bull Racing",
  "country": "Austria"
}

###

### TEAMS - UPDATE
PUT {{baseUrl}}/api/teams/{{teamId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated Team"
}

###

### TEAMS - DELETE
DELETE {{baseUrl}}/api/teams/{{teamId}}
Authorization: Bearer {{token}}

###

### RACES - GET ALL
GET {{baseUrl}}/api/races
Authorization: Bearer {{token}}

###

### RACES - GET BY ID
GET {{baseUrl}}/api/races/{{raceId}}
Authorization: Bearer {{token}}

###

### RACES - CREATE
POST {{baseUrl}}/api/races
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Spa GP",
  "track": "Spa-Francorchamps",
  "date": "2026-04-01",
  "team": "{{teamId}}"
}

###

### RACES - UPDATE
PUT {{baseUrl}}/api/races/{{raceId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated Race"
}

###

### RACES - DELETE
DELETE {{baseUrl}}/api/races/{{raceId}}
Authorization: Bearer {{token}}

###

### REGISTRATIONS - GET ALL
GET {{baseUrl}}/api/registrations
Authorization: Bearer {{token}}

###

### REGISTRATIONS - GET BY ID
GET {{baseUrl}}/api/registrations/{{registrationId}}
Authorization: Bearer {{token}}

###

### REGISTRATIONS - CREATE
POST {{baseUrl}}/api/registrations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "user": "{{userId}}",
  "race": "{{raceId}}",
  "position": 1
}

###

### REGISTRATIONS - UPDATE
PUT {{baseUrl}}/api/registrations/{{registrationId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "position": 2
}

###

### REGISTRATIONS - DELETE
DELETE {{baseUrl}}/api/registrations/{{registrationId}}
Authorization: Bearer {{token}}
